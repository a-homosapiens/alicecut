# 依赖与构建产物
node_modules/
out/
dist/
coverage/
release/
*.tsbuildinfo

# Local configuration and disposable diagnostics
.env
.env.*
!.env.example
.probe/
.claude/

# 首装只打包三款基础字体；其余字体位于 font-assets/，由客户端按需从 GitHub 获取。
public/fonts/*.ttf
public/fonts/*.otf
!public/fonts/SmileySans-Oblique.ttf
!public/fonts/NotoSansSC[[]wght].ttf
!public/fonts/Inter[[]opsz,wght].ttf

# Local samples are private development fixtures and never belong in Git.
/samples/

# 系统与编辑器
.DS_Store
Thumbs.db
*.log
